                    if (partnerMap[trimmedLower]) {
                        fv.fuelVendor = partnerMap[trimmedLower];
                    }
                }
            });
        }

        // Standardize shipment customer names
        if (this.state.shipments) {
            this.state.shipments.forEach(s => {
